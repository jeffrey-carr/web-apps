{
  "name": "federation-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "echo \"starting vite\" && vite dev --host --logLevel info && echo \"done\"",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "@jeffrey-carr/frontend-common": "file:../../../packages/frontend-common",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "sass": "^1.80.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.8"
  }
}
