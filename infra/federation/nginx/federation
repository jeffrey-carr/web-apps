map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    server_name login.jeffreycarr.dev;

    location / {
        proxy_pass http://localhost:3001;  # federation_frontend
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    location /api/ {
        proxy_pass http://localhost:3101;  # federation_backend
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_cache_bypass $http_upgrade;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/login.jeffreycarr.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/login.jeffreycarr.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = login.jeffreycarr.dev) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name login.jeffreycarr.dev;
    return 404;
}

